{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",                        
    "esModuleInterop": true,                       
    "resolveJsonModule": true,                     
    "moduleResolution": "node",                   
    "types": ["node"],                             
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "unit-tests/*": ["src/*"],
      "e2e-tests/*": ["tests/*"]
    }
  }
}